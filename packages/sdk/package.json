  ],
  "homepage": "https://github.com/sinameraji/sbx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinameraji/sbx.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
