{
  "name": "sbx",
  "version": "0.0.1",
  "private": true,
  "description": "Self-hostable sandbox infrastructure for AI agents. Run many isolated, observable sandboxes on your own hardware.",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:daemon": "npm run dev --workspace @sbx/daemon",
    "dev:cli": "npm run dev --workspace @sbx/cli",
    "smoke": "npm run build && node packages/daemon/dist/smoke.js"
  },
  "engines": {
    "node": ">=20"
  }
}
