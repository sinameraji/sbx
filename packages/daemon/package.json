{
  "name": "@hotcell/daemon",
  "version": "0.1.4",
  "description": "hotcell sandbox daemon: containers + Firecracker/Apple-VZ microVMs, egress credential gateway",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "hotcelld": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dockerode": "^4.0.2"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "@types/node": "^22.5.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "@hotcell/sdk": "^0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinameraji/hotcell.git"
  },
  "homepage": "https://hotcell.sh",
  "bugs": {
    "url": "https://github.com/sinameraji/hotcell/issues"
  },
  "keywords": [
    "sandbox",
    "ai-agents",
    "firecracker",
    "microvm",
    "apple-virtualization",
    "code-execution",
    "llm-gateway",
    "self-hosted"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
