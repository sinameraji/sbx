{
  "name": "hotcell",
  "version": "0.1.8",
  "description": "Sandboxes for AI agents, on your own hardware — CLI + daemon for the hotcell sandbox platform",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "hotcell": "dist/index.js",
    "hc": "dist/index.js",
    "hotcelld": "dist/daemon.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/index.ts",
    "prepack": "cp ../../README.md ./README.md"
  },
  "dependencies": {
    "@hotcell/sdk": "0.1.8",
    "@hotcell/daemon": "0.1.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinameraji/hotcell.git"
  },
  "homepage": "https://hotcell.sh",
  "bugs": {
    "url": "https://github.com/sinameraji/hotcell/issues"
  },
  "keywords": [
    "sandbox",
    "ai-agents",
    "firecracker",
    "microvm",
    "apple-virtualization",
    "code-execution",
    "llm-gateway",
    "self-hosted"
  ],
  "engines": {
    "node": ">=22"
  }
}
