{
  "name": "@sbx/sdk",
  "version": "0.0.1",
  "description": "TypeScript client SDK for sbx — self-hostable agent sandboxes",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "keywords": ["sandbox", "ai-agents", "sbx", "code-execution", "self-hosted"],
  "homepage": "https://github.com/sinameraji/sbx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinameraji/sbx.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
