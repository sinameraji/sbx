{
  "name": "@hotcell/sdk",
  "version": "0.1.0",
  "description": "Zero-dependency TypeScript client for the hotcell sandbox daemon",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
